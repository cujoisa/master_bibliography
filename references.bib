@ARTICLE{Dugourd2021-bs,
  title     = "Causal integration of multi-omics data with prior knowledge to
               generate mechanistic hypotheses",
  author    = "Dugourd, Aurelien and Kuppe, Christoph and Sciacovelli, Marco and
               Gjerga, Enio and Gabor, Attila and Emdal, Kristina B and Vieira,
               Vitor and Bekker-Jensen, Dorte B and Kranz, Jennifer and Bindels,
